# Virtual environment
venv/
ENV/
env/

# Python compiled files
*.pyc
__pycache__/

# SQLite database
*.sqlite3

# Local settings
*.local.json

# Environment variables (NEVER commit secrets)
.env
.env.*
!.env.example

# Collected static files (regenerated by collectstatic)
staticfiles/

# User uploads (regenerated; on Render they live on a persistent disk)
media/

# IDE / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Word lockfiles and temp files
~$*.docx
~$*.txt
*.tmp

# Draw.io backup and temp files
diagrams/.$*.bkp
diagrams/.$*.dtmp
diagrams/.~*
