# =============================================================================
# Hostel Information Management System — environment variables
# Copy this file to ".env" for local use, or set these in the Render dashboard.
# =============================================================================

# --- Django core --------------------------------------------------------------

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# "False" in production, "True" only for local development.
DJANGO_DEBUG=False

# Comma-separated list of hostnames Django will accept.
# Render's hostname is auto-appended at runtime via RENDER_EXTERNAL_HOSTNAME,
# so ".onrender.com" is usually sufficient.
DJANGO_ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1

# Comma-separated list of full origins (scheme + host) trusted for CSRF.
# Required because Django 4+ enforces this for cross-origin form posts.
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# --- Database -----------------------------------------------------------------

# REQUIRED in production. Render injects this automatically when you link the
# managed PostgreSQL database in render.yaml. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
# If unset, the project falls back to the local sqlite db.sqlite3 file.
DATABASE_URL=postgres://user:password@host:5432/hostel_system

# --- HTTPS / security (production only) ---------------------------------------

# Force HTTP -> HTTPS redirect. Keep "True" on Render.
DJANGO_SECURE_SSL_REDIRECT=True

# HSTS max-age in seconds. Start small (3600) and raise once you're confident.
DJANGO_SECURE_HSTS_SECONDS=3600

# --- Media uploads ------------------------------------------------------------

# Where Django writes uploaded payment receipts. On Render, point this at the
# mount path of the persistent disk attached to the web service.
DJANGO_MEDIA_ROOT=/opt/render/project/src/media
