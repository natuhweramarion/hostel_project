# =============================================================================
# Hostel Information Management System — environment variables
#
# LOCAL DEV : copy this file to ".env" and fill in real values.
#             Load it before running Django:
#               set -a && source .env && set +a
#             Or use python-dotenv / direnv / your IDE's .env support.
#
# RENDER.COM: set these in the Render dashboard (Environment tab), or let
#             render.yaml inject them automatically (see render.yaml).
#
# NEVER commit a real .env file — it is already excluded in .gitignore.
# =============================================================================


# --- Django core --------------------------------------------------------------

# REQUIRED in production. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# render.yaml uses generateValue: true so Render auto-creates one.
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# "True" for local dev, "False" in all deployed environments.
DJANGO_DEBUG=True

# Comma-separated list of hostnames Django will accept.
# Render auto-appends RENDER_EXTERNAL_HOSTNAME at runtime (handled in settings.py),
# so ".onrender.com" covers every *.onrender.com subdomain in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of full origins (scheme + host) trusted for CSRF.
# Django 4+ requires this for cross-origin form submissions.
# For Render: "https://*.onrender.com" covers all preview and production URLs.
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000


# --- Database -----------------------------------------------------------------

# REQUIRED in production. Render injects this automatically when you link the
# managed PostgreSQL database via render.yaml. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Leave blank for local dev — settings.py falls back to db.sqlite3.
DATABASE_URL=


# --- HTTPS / security (production only — leave blank for local dev) -----------

# Force HTTP → HTTPS redirect. Set "True" on Render; leave blank locally.
DJANGO_SECURE_SSL_REDIRECT=

# HSTS max-age in seconds. 0 = disabled (safe locally).
# Use 3600 on Render to start; raise to 31536000 (1 year) once stable.
DJANGO_SECURE_HSTS_SECONDS=0


# --- Media uploads ------------------------------------------------------------

# Where Django writes uploaded payment receipt files.
# WARNING: Render free tier has an ephemeral filesystem — files are wiped on
# every deploy. Attach a Render persistent disk and point this to its mount
# path (e.g. /opt/render/project/src/media), or migrate uploads to Cloudinary/S3.
# Leave blank to use the default: <project_root>/media
DJANGO_MEDIA_ROOT=


# --- Superuser auto-creation --------------------------------------------------
#
# Used by: build.sh → python manage.py ensure_superuser
# On Render, set these three vars in the dashboard (Environment tab), NOT here,
# since this file may be shared. build.sh skips gracefully if they are absent.
#
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-use-a-strong-password
